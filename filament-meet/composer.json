{
    "name": "atifullahmamond/filament-meet",
    "description": "Real-time video meetings (Jitsi Meet) for Filament PHP v5 — Google Meet-style rooms in your Filament panel.",
    "keywords": ["laravel", "filament", "filament-plugin", "video", "meet", "jitsi", "livewire"],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/atifullahmamond/packages/tree/main/filament-meet",
    "support": {
        "issues": "https://github.com/atifullahmamond/packages/issues",
        "source": "https://github.com/atifullahmamond/packages"
    },
    "authors": [
        {
            "name": "Atifullah Mamond",
            "homepage": "https://github.com/atifullahmamond"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Atifullahmamond\\FilamentMeet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atifullahmamond\\FilamentMeet\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Atifullahmamond\\FilamentMeet\\FilamentMeetServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}